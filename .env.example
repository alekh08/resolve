# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: PostgreSQL connection URL (Transaction pooler in Supabase)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: Direct PostgreSQL connection URL (Session pooler in Supabase for Prisma Migrate)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT_SECRET: Secret key for signing JWT login tokens
JWT_SECRET="super-secret-resolve-hackathon-token"

# LIVEKIT_API_KEY: API Key for LiveKit OSS
LIVEKIT_API_KEY="devkey"

# LIVEKIT_API_SECRET: Secret for LiveKit OSS
LIVEKIT_API_SECRET="secret"

# LIVEKIT_URL: LiveKit Server URL
LIVEKIT_URL="ws://localhost:7800"

# SUPABASE_URL: Your Supabase Project URL (Settings > API > Project URL)
SUPABASE_URL="https://[your-project-ref].supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: service_role secret key (Settings > API > service_role)
# WARNING: Keep this server-side only. Never expose in the frontend.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
