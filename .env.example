# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: SQLite or PostgreSQL connection URL
DATABASE_URL="file:./dev.db"

# JWT_SECRET: Secret key for signing JWT login tokens
JWT_SECRET="super-secret-resolve-hackathon-token"

# LIVEKIT_API_KEY: API Key for LiveKit OSS
LIVEKIT_API_KEY="devkey"

# LIVEKIT_API_SECRET: Secret for LiveKit OSS
LIVEKIT_API_SECRET="secret"

# LIVEKIT_URL: LiveKit Server URL
LIVEKIT_URL="ws://localhost:7800"
